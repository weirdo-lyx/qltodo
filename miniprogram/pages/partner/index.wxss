.partner-hero,
.partner-empty-hero {
  overflow: hidden;
  background: linear-gradient(135deg, #fffaf2 0%, #edf8ef 100%);
}

.partner-name {
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 16rpx;
  color: #4a3528;
}

.checkin-item,
.plan-item {
  padding: 22rpx 0;
  border-bottom: 1rpx solid rgba(116, 75, 45, 0.1);
}

.checkin-item:last-child,
.plan-item:last-child {
  border-bottom: none;
}

.checkin-title,
.plan-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #4a3528;
}

.checkin-meta,
.plan-meta,
.invite-expire {
  margin-top: 10rpx;
  color: #947b69;
  font-size: 24rpx;
}

.invite-box {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  background: #fff0da;
  border: 2rpx dashed rgba(140, 90, 46, 0.18);
  text-align: center;
}

.invite-code {
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: 8rpx;
  color: #ce6548;
}

.bind-btn {
  margin-top: 20rpx;
}

.empty-inline {
  color: #947b69;
  padding-top: 12rpx;
}
