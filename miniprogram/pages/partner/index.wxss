.partner-hero,
.partner-empty-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  overflow: hidden;
}

.partner-copy {
  flex: 1;
}

.partner-bear {
  flex: 0 0 172rpx;
  width: 172rpx;
  height: 172rpx;
}

.partner-name {
  font-size: 40rpx;
  font-weight: 800;
  margin: 20rpx 0 16rpx;
  color: #4b2f25;
  line-height: 1.2;
}

.checkin-item,
.plan-item {
  padding: 22rpx 0;
  border-bottom: 1rpx dashed rgba(75, 47, 37, 0.12);
}

.checkin-item:last-child,
.plan-item:last-child {
  border-bottom: none;
}

.checkin-title,
.plan-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #4b2f25;
}

.checkin-meta,
.plan-meta,
.invite-expire {
  margin-top: 10rpx;
  color: #8d7467;
  font-size: 24rpx;
}

.invite-box {
  margin-top: 24rpx;
  padding: 28rpx;
  border-radius: 16rpx;
  background: #fff1db;
  border: 2rpx dashed rgba(75, 47, 37, 0.18);
  text-align: center;
}

.invite-code {
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: 8rpx;
  color: #c85d50;
}

.bind-btn {
  margin-top: 20rpx;
}

.empty-inline {
  color: #8d7467;
  padding-top: 12rpx;
}

.page > .btn-danger {
  margin-top: 24rpx;
}
