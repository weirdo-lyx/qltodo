.header-card {
  overflow: hidden;
}

.detail-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.detail-copy {
  flex: 1;
}

.mini-bear {
  flex: 0 0 104rpx;
  width: 104rpx;
  height: 104rpx;
}

.plan-title {
  margin-top: 18rpx;
  font-size: 38rpx;
  font-weight: 800;
  color: #4b2f25;
  line-height: 1.25;
}

.plan-date {
  margin-top: 12rpx;
  color: #8d7467;
}

.summary-row {
  display: flex;
  gap: 24rpx;
  margin-top: 32rpx;
}

.summary-item {
  flex: 1;
  padding: 24rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.8);
  border: 2rpx solid rgba(75, 47, 37, 0.08);
}

.summary-num {
  font-size: 42rpx;
  font-weight: 700;
  color: #ff6f68;
}

.summary-label {
  margin-top: 10rpx;
  color: #8d7467;
  font-size: 24rpx;
}

.task-single,
.task-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  padding-top: 20rpx;
  border-top: 2rpx dashed rgba(75, 47, 37, 0.12);
}

.task-done {
  opacity: 0.56;
}

.task-main {
  flex: 1;
}

.task-points {
  font-size: 26rpx;
  color: #8d7467;
}

.task-btn {
  min-width: 168rpx;
  margin: 0;
  padding: 18rpx 24rpx;
  font-size: 26rpx;
}

.btn-undo {
  background: #fff1db;
  color: #8d5e35;
  border-radius: 999rpx;
  font-size: 26rpx;
  line-height: 1.4;
}

.danger-zone {
  margin-top: 24rpx;
  text-align: center;
}
