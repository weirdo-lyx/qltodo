.profile-card {
  text-align: center;
  padding-top: 42rpx;
  padding-bottom: 52rpx;
}

.profile-bears {
  width: 184rpx;
  height: 184rpx;
  margin: 0 auto 24rpx;
}

.avatar-wrap {
  margin-top: 24rpx;
  display: flex;
  justify-content: center;
}

.avatar {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: #fff3e3;
  border: 6rpx solid #ffffff;
  box-shadow: 0 14rpx 26rpx rgba(122, 87, 75, 0.12);
}

.placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 52rpx;
  color: #cf6a5f;
  font-weight: 800;
}

.nickname {
  margin-top: 24rpx;
  font-size: 38rpx;
  font-weight: 800;
  color: #5a3d33;
}

.points {
  margin-top: 12rpx;
  color: #7d6053;
}

.action-card {
  margin-top: 24rpx;
}

.action-btn {
  margin-top: 20rpx;
}
