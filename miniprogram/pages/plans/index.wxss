.top-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #fffaf2 0%, #edf8ef 100%);
}

.top-action button {
  flex: 0 0 188rpx;
  margin: 0;
  padding: 18rpx 20rpx;
}

.plan-card {
  margin-top: 24rpx;
}

.plan-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.plan-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: #4a3528;
}

.plan-info {
  margin-top: 10rpx;
  color: #765b49;
}

.empty-btn {
  margin-top: 24rpx;
}

.plan-actions {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(116, 75, 45, 0.1);
  text-align: right;
}

.btn-sm {
  display: inline-block;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  border-radius: 999rpx;
}
