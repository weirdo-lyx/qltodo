.top-action {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.top-copy {
  flex: 1;
}

.top-side {
  flex: 0 0 188rpx;
}

.top-bears {
  width: 188rpx;
  height: 144rpx;
  margin-bottom: 16rpx;
}

.top-action button {
  width: 188rpx;
  margin: 0;
  padding: 18rpx 20rpx;
}

.plan-card {
  margin-top: 24rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(255, 249, 244, 0.96) 100%);
}

.plan-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 20rpx;
  margin-bottom: 16rpx;
}

.plan-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 800;
  color: #5a3d33;
  line-height: 1.35;
}

.plan-info {
  margin-top: 12rpx;
  padding: 18rpx 22rpx;
  border-radius: 20rpx;
  background: linear-gradient(180deg, #fff8f3 0%, #fffdfb 100%);
  color: #7e6053;
}

.empty-btn {
  margin-top: 24rpx;
}

.plan-actions {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed rgba(120, 84, 70, 0.12);
  text-align: right;
}

.btn-sm {
  display: inline-block;
  padding: 12rpx 28rpx;
  font-size: 24rpx;
  border-radius: 999rpx;
}
