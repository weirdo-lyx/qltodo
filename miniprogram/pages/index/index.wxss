.home-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.home-copy {
  flex: 1;
}

.home-bears {
  flex: 0 0 230rpx;
  width: 230rpx;
  height: 152rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.summary-card {
  position: relative;
  overflow: hidden;
  min-height: 228rpx;
  padding: 30rpx;
  border: 3rpx solid rgba(120, 84, 70, 0.08);
  border-radius: 28rpx;
  box-shadow: 0 16rpx 32rpx rgba(122, 87, 75, 0.08);
}

.summary-primary {
  background:
    radial-gradient(circle at top left, rgba(255, 247, 220, 0.32) 0, rgba(255, 247, 220, 0) 34%),
    repeating-linear-gradient(45deg, rgba(255, 255, 255, 0.18) 0, rgba(255, 255, 255, 0.18) 18rpx, transparent 18rpx, transparent 36rpx),
    linear-gradient(135deg, #ffbf87 0%, #ff8a7b 100%);
  color: #ffffff;
  box-shadow: 0 18rpx 34rpx rgba(241, 136, 92, 0.22);
}

.summary-primary .summary-label,
.summary-primary .summary-value {
  position: relative;
  z-index: 1;
}

.summary-sticker {
  position: absolute;
  right: -14rpx;
  bottom: -14rpx;
  width: 156rpx;
  height: 156rpx;
  opacity: 0.92;
}

.summary-label {
  font-size: 26rpx;
  opacity: 0.92;
}

.summary-value {
  margin-top: 20rpx;
  font-size: 58rpx;
  font-weight: 800;
}

.summary-date {
  margin-top: 16rpx;
  color: #8d7467;
  font-size: 24rpx;
}

.plan-card {
  margin-top: 24rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.96) 0%, rgba(255, 249, 245, 0.96) 100%);
}

.plan-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.plan-title {
  font-size: 32rpx;
  font-weight: 800;
  color: #5a3d33;
}

.plan-subtitle {
  margin-top: 8rpx;
  color: #977d71;
  font-size: 24rpx;
}

.task-single,
.task-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  margin-top: 18rpx;
  padding-top: 24rpx;
  border-top: 2rpx dashed rgba(120, 84, 70, 0.12);
}

.task-done {
  opacity: 0.56;
}

.task-main {
  flex: 1;
}

.task-points {
  font-size: 26rpx;
  color: #977d71;
}

.task-btn {
  min-width: 168rpx;
  margin: 0;
  padding: 18rpx 24rpx;
  font-size: 26rpx;
}

.btn-undo {
  background: linear-gradient(135deg, #fff0d6 0%, #fff7e9 100%);
  color: #8d6041;
  border-radius: 999rpx;
  font-size: 26rpx;
  line-height: 1.4;
}

.empty-btn {
  margin-top: 24rpx;
}
