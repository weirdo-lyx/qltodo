.points-hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  margin-bottom: 28rpx;
}

.points-copy {
  flex: 1;
}

.points-bear {
  flex: 0 0 172rpx;
  width: 172rpx;
  height: 184rpx;
}

.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.stat-card {
  position: relative;
  overflow: hidden;
  min-height: 206rpx;
  border-radius: 28rpx;
}

.stat-total {
  background: linear-gradient(135deg, #fff7e8 0%, #ffe6d9 100%);
}

.stat-today {
  background: linear-gradient(135deg, #edf9f3 0%, #e7f2ff 100%);
}

.summary-label {
  font-size: 26rpx;
  color: #977d71;
}

.summary-value {
  margin-top: 24rpx;
  font-size: 52rpx;
  font-weight: 800;
}

.log-card {
  margin-top: 24rpx;
}

.log-item {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx dashed rgba(120, 84, 70, 0.12);
}

.log-item:last-child {
  border-bottom: none;
}

.log-reason {
  font-size: 30rpx;
  font-weight: 800;
  color: #5a3d33;
}

.log-time,
.log-balance {
  margin-top: 10rpx;
  color: #977d71;
  font-size: 24rpx;
}

.log-right {
  text-align: right;
}

.log-change {
  font-size: 36rpx;
  font-weight: 800;
}

.danger {
  color: #d35a4c;
}

.empty-inline {
  color: #977d71;
  padding-top: 20rpx;
  text-align: center;
}

.inline-bear {
  width: 168rpx;
  height: 168rpx;
  margin: 0 auto 18rpx;
}

.more-btn {
  margin-top: 24rpx;
}
