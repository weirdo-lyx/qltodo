.points-hero {
  margin-bottom: 24rpx;
  background: linear-gradient(135deg, #fffaf2 0%, #edf8ef 100%);
}

.summary-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.stat-card {
  min-height: 200rpx;
}

.summary-label {
  font-size: 26rpx;
  color: #947b69;
}

.summary-value {
  margin-top: 24rpx;
  font-size: 52rpx;
  font-weight: 700;
}

.log-card {
  margin-top: 24rpx;
}

.log-item {
  display: flex;
  justify-content: space-between;
  gap: 20rpx;
  padding: 24rpx 0;
  border-bottom: 1rpx solid rgba(116, 75, 45, 0.1);
}

.log-item:last-child {
  border-bottom: none;
}

.log-reason {
  font-size: 30rpx;
  font-weight: 700;
  color: #4a3528;
}

.log-time,
.log-balance {
  margin-top: 10rpx;
  color: #947b69;
  font-size: 24rpx;
}

.log-right {
  text-align: right;
}

.log-change {
  font-size: 36rpx;
  font-weight: 700;
}

.danger {
  color: #d35a4c;
}

.empty-inline {
  color: #947b69;
  padding-top: 20rpx;
}

.more-btn {
  margin-top: 24rpx;
}
