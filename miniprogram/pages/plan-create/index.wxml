<view class="page">
  <view class="card create-hero">
    <view>
      <view class="cozy-title">新建约定</view>
      <view class="cozy-subtitle">给两个人的坚持起个可爱的名字。</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">计划信息</view>
    <input class="input" placeholder="请输入计划名称" value="{{title}}" bindinput="handleTitleChange" />
    <input class="input form-gap" type="number" placeholder="计划天数" value="{{totalDays}}" bindinput="handleDaysChange" />
    <input class="input form-gap" type="number" placeholder="每次打卡奖励积分" value="{{points}}" bindinput="handlePointsChange" />
  </view>

  <button class="btn-primary submit-btn" bindtap="handleSubmit" loading="{{loading}}">提交创建</button>
</view>
