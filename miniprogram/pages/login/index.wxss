.login-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24rpx;
  padding-top: 72rpx;
}

.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  overflow: hidden;
  padding-top: 44rpx;
  padding-bottom: 40rpx;
  color: #4b2f25;
}

.hero-copy {
  flex: 1;
}

.hero-title {
  margin-top: 24rpx;
  font-size: 48rpx;
  font-weight: 800;
  line-height: 1.14;
}

.hero-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #73564a;
}

.hero-bears {
  flex: 0 0 230rpx;
  width: 230rpx;
  height: 132rpx;
}

.sticker-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.login-sticker {
  height: 176rpx;
  background: #ffffff;
}

.action-card {
  padding-top: 32rpx;
}

.login-btn {
  margin-top: 20rpx;
}

.login-tip {
  margin-top: 24rpx;
  color: #8d7467;
  text-align: center;
  font-size: 24rpx;
}
