.login-page {
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 24rpx;
  padding-top: 88rpx;
}

.hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  overflow: hidden;
  padding-top: 44rpx;
  padding-bottom: 40rpx;
  background:
    radial-gradient(circle at 92% 12%, rgba(137, 203, 178, 0.32) 0, rgba(137, 203, 178, 0) 28%),
    linear-gradient(135deg, #fff3da 0%, #ffe8df 58%, #eef8ec 100%);
  color: #4a3528;
}

.hero-copy {
  flex: 1;
}

.hero-badge {
  display: inline-flex;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #ce6548;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 24rpx;
  font-size: 52rpx;
  font-weight: 800;
}

.hero-desc {
  margin-top: 16rpx;
  font-size: 28rpx;
  line-height: 1.7;
  color: #765b49;
}

.hero-bears {
  flex: 0 0 230rpx;
  width: 230rpx;
  height: 132rpx;
  overflow: hidden;
  border: 6rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 18rpx;
  box-shadow: 0 12rpx 24rpx rgba(116, 75, 45, 0.12);
}

.action-card {
  padding-top: 32rpx;
}

.login-btn {
  margin-top: 20rpx;
}

.login-tip {
  margin-top: 24rpx;
  color: #947b69;
  text-align: center;
  font-size: 24rpx;
}
