<view class="page login-page">
  <view class="hero card bear-hero">
    <view class="hero-copy">
      <view class="bear-chip">布布一二打卡局</view>
      <view class="hero-title">和布布一二一起打卡</view>
      <view class="hero-desc">把两个人的小坚持，贴成每天都想打开看的可爱记录。</view>
    </view>
    <view class="hero-bears bear-frame">
      <image class="bear-art" src="/assets/bears/bubu-yier-hi.jpeg" mode="aspectFill" />
    </view>
  </view>

  <view class="sticker-row">
    <view class="login-sticker bear-frame">
      <image class="bear-art" src="/assets/bears/72ddba9eab32e8abcb3c565df7ef0734.jpg" mode="aspectFit" />
    </view>
    <view class="login-sticker bear-frame">
      <image class="bear-art" src="/assets/bears/8acc28dfe40e7aa221dfb8cf838789e0.jpg" mode="aspectFit" />
    </view>
  </view>

  <view class="card action-card">
    <view class="section-title">选择一只小熊</view>
    <button class="btn-primary login-btn" bindtap="handleMockLoginA" loading="{{loading}}">布布测试号登录</button>
    <button class="btn-secondary login-btn" bindtap="handleMockLoginB" loading="{{loading}}">一二测试号登录</button>
    <button class="btn-secondary login-btn" bindtap="handleWxLogin" loading="{{loading}}">微信登录</button>
    <view class="login-tip">mock 登录保留着，方便测试两个人绑定流程。</view>
  </view>
</view>
