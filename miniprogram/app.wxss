page {
  min-height: 100%;
  background:
    radial-gradient(circle at top left, rgba(255, 221, 206, 0.7) 0, rgba(255, 221, 206, 0) 28%),
    radial-gradient(circle at top right, rgba(250, 239, 194, 0.78) 0, rgba(250, 239, 194, 0) 26%),
    radial-gradient(circle at bottom center, rgba(215, 242, 228, 0.72) 0, rgba(215, 242, 228, 0) 32%),
    linear-gradient(180deg, #fffaf4 0%, #fff5ef 44%, #f7fbf6 100%);
  color: #5a3d33;
  font-size: 28rpx;
}

view,
text,
button,
input,
textarea,
image {
  box-sizing: border-box;
}

button::after {
  border: none;
}

.page {
  min-height: 100vh;
  padding: 28rpx 24rpx calc(180rpx + env(safe-area-inset-bottom));
}

.card {
  position: relative;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.94);
  border: 3rpx solid rgba(120, 84, 70, 0.08);
  border-radius: 28rpx;
  padding: 30rpx;
  box-shadow: 0 18rpx 40rpx rgba(122, 87, 75, 0.08);
}

.card::after {
  content: '';
  position: absolute;
  top: 0;
  right: 0;
  width: 180rpx;
  height: 120rpx;
  background: radial-gradient(circle at top right, rgba(255, 233, 224, 0.8) 0, rgba(255, 233, 224, 0) 72%);
  pointer-events: none;
}

.card + .card {
  margin-top: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 800;
  margin-bottom: 20rpx;
  color: #5a3d33;
}

.section-title::before {
  content: '';
  display: inline-block;
  width: 14rpx;
  height: 14rpx;
  margin-right: 10rpx;
  border-radius: 50%;
  background: #ff7f75;
  box-shadow: 18rpx 0 0 #ffd879;
  vertical-align: 3rpx;
}

.muted {
  color: #977d71;
}

.primary {
  color: #ff7d73;
}

.btn-primary,
.btn-secondary,
.btn-danger,
.btn-disabled {
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 800;
  line-height: 1.4;
  box-shadow: 0 12rpx 20rpx rgba(122, 87, 75, 0.1);
  border: 3rpx solid rgba(120, 84, 70, 0.08);
}

.btn-primary {
  background: linear-gradient(135deg, #ffb08d 0%, #ff7d73 100%);
  color: #ffffff;
}

.btn-secondary {
  background: linear-gradient(135deg, #eef8f2 0%, #e1f3ec 100%);
  color: #547666;
}

.btn-danger {
  background: linear-gradient(135deg, #fff0ea 0%, #ffe2dc 100%);
  color: #d76d63;
}

.btn-disabled {
  background: #efe9e1;
  color: #b4a08f;
  box-shadow: none;
}

.empty-state,
.loading-state {
  margin-top: 80rpx;
  padding: 68rpx 32rpx;
  text-align: center;
  color: #977d71;
  background: rgba(255, 255, 255, 0.94);
  border: 3rpx dashed rgba(120, 84, 70, 0.16);
  border-radius: 28rpx;
  box-shadow: 0 18rpx 40rpx rgba(122, 87, 75, 0.06);
}

.empty-bear,
.loading-bear {
  width: 188rpx;
  height: 188rpx;
  margin: 0 auto 24rpx;
  overflow: hidden;
  border: 8rpx solid #ffffff;
  border-radius: 28rpx;
  background: #fffaf3;
  box-shadow: 0 14rpx 28rpx rgba(122, 87, 75, 0.1);
}

.input {
  width: 100%;
  min-height: 88rpx;
  padding: 24rpx;
  border: 3rpx solid rgba(120, 84, 70, 0.1);
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fffaf4 0%, #ffffff 100%);
  color: #5a3d33;
  box-shadow: inset 0 4rpx 12rpx rgba(255, 236, 229, 0.4);
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 20rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 800;
}

.tag-primary {
  background: linear-gradient(135deg, #ffe5da 0%, #fff0ea 100%);
  color: #d0685c;
}

.tag-success {
  background: linear-gradient(135deg, #e5f7ec 0%, #f0fbf4 100%);
  color: #4b946d;
}

.tag-muted {
  background: #f4ede5;
  color: #977d71;
}

.bear-art {
  display: block;
  width: 100%;
  height: 100%;
}

.bear-frame {
  overflow: hidden;
  border: 8rpx solid #ffffff;
  border-radius: 26rpx;
  background: #fffaf3;
  box-shadow: 0 12rpx 28rpx rgba(122, 87, 75, 0.14);
}

.bear-chip {
  display: inline-flex;
  align-items: center;
  min-height: 44rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #fff0d8 0%, #fff7ea 100%);
  border: 2rpx solid rgba(120, 84, 70, 0.08);
  color: #ce695e;
  font-size: 22rpx;
  font-weight: 800;
}

.bear-hero {
  background:
    radial-gradient(circle at top left, rgba(255, 248, 214, 0.92) 0, rgba(255, 248, 214, 0) 34%),
    radial-gradient(circle at bottom right, rgba(226, 247, 235, 0.84) 0, rgba(226, 247, 235, 0) 36%),
    linear-gradient(135deg, rgba(255, 241, 229, 0.98) 0%, rgba(255, 247, 242, 0.98) 52%, rgba(244, 251, 247, 0.98) 100%);
}

.cozy-title {
  color: #5a3d33;
  font-size: 40rpx;
  font-weight: 800;
  line-height: 1.25;
}

.cozy-subtitle {
  margin-top: 12rpx;
  color: #977d71;
  font-size: 24rpx;
  line-height: 1.7;
}
