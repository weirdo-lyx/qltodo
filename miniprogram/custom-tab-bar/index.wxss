.tab-shell {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  padding: 0 20rpx calc(18rpx + env(safe-area-inset-bottom));
  pointer-events: none;
}

.tab-bar {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  gap: 14rpx;
  min-height: 132rpx;
  padding: 14rpx 16rpx 18rpx;
  border: 3rpx solid rgba(120, 84, 70, 0.08);
  border-radius: 40rpx;
  background: rgba(255, 250, 243, 0.96);
  box-shadow: 0 18rpx 40rpx rgba(122, 87, 75, 0.14);
  backdrop-filter: blur(18rpx);
  pointer-events: auto;
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  min-height: 96rpx;
  padding: 10rpx 8rpx 6rpx;
  border-radius: 30rpx;
  color: #9d8376;
  transition: all 0.2s ease;
}

.tab-item.is-active {
  background: linear-gradient(180deg, rgba(255, 236, 227, 0.92) 0%, rgba(255, 247, 240, 0.96) 100%);
  box-shadow: inset 0 0 0 2rpx rgba(255, 153, 139, 0.12);
  color: #ff7d73;
}

.tab-thumb-wrap {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 54rpx;
  height: 54rpx;
  padding: 4rpx;
  border-radius: 999rpx;
  background: #fff3e9;
  box-shadow: 0 8rpx 16rpx rgba(122, 87, 75, 0.12);
}

.tab-thumb {
  width: 100%;
  height: 100%;
  border-radius: 999rpx;
}

.tab-item.is-active .tab-thumb-wrap {
  width: 66rpx;
  height: 66rpx;
  transform: translateY(-6rpx);
}

.tab-label {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
}

.accent-peach {
  background: linear-gradient(135deg, #ffe3d6 0%, #fff4eb 100%);
}

.accent-cream {
  background: linear-gradient(135deg, #fff0cb 0%, #fff8e7 100%);
}

.accent-mint {
  background: linear-gradient(135deg, #dff6ea 0%, #eefcf6 100%);
}

.accent-pink {
  background: linear-gradient(135deg, #ffe2e6 0%, #fff2f5 100%);
}
