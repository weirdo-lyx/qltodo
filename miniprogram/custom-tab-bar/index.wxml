<view class="tab-shell">
  <view class="tab-bar">
    <block wx:for="{{list}}" wx:key="pagePath">
      <view
        class="tab-item {{selected === index ? 'is-active' : ''}}"
        data-index="{{index}}"
        data-path="{{item.pagePath}}"
        bindtap="switchTab"
      >
        <view class="tab-thumb-wrap {{item.accent}}">
          <image class="tab-thumb" src="{{item.image}}" mode="aspectFill" />
        </view>
        <view class="tab-label">{{item.text}}</view>
      </view>
    </block>
  </view>
</view>
